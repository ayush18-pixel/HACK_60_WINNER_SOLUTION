# Shared auth
AUTH_SECRET=change-me-to-a-long-random-string
NEXTAUTH_SECRET=change-me-to-a-long-random-string

# Frontend
NEXTAUTH_URL=http://127.0.0.1:3000
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
HYPERNEWS_BACKEND_URL=http://127.0.0.1:8000

# Durable storage
DATABASE_URL=sqlite:///./data/hypernews.db

# Optional state/cache backends
# REDIS_URL=redis://localhost:6379
# QDRANT_URL=http://localhost:6333
# OPENSEARCH_URL=http://localhost:9200

# Runtime profile
HYPERNEWS_MAX_ARTICLES=10000
HYPERNEWS_GRAPH_ARTICLE_LIMIT=1000
HYPERNEWS_ENABLE_GRAPH=1
HYPERNEWS_ENABLE_SENTENCE_TRANSFORMER=1
HYPERNEWS_ENABLE_RERANKER=1
HYPERNEWS_ENABLE_QDRANT=1
HYPERNEWS_ENABLE_OPENSEARCH=1

# Optional explanations
# GROQ_API_KEY=
